<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-12 mb-3">
            <a href="/listings" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Listings
            </a>
        </div>
    </div>
    
    <div class="card shadow-lg">
        <img src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1518780664697-55e3ad937233?q=80&w=1965' %>" 
             class="card-img-top" 
             alt="<%= listing.title %>"
             style="height: 400px; object-fit: cover;">
        
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h1 class="card-title display-5"><%= listing.title %></h1>
                    <p class="text-muted">
                        <i class="fas fa-map-marker-alt me-2"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                </div>
                <div class="text-end">
                    <h2 class="text-primary mb-0">
                        <i class="fas fa-tag me-2"></i>
                        $<%= listing.price ? listing.price.toLocaleString() : 'N/A' %>
                    </h2>
                </div>
            </div>
            
            <hr>
            
            <h4>Description</h4>
            <p class="card-text"><%= listing.description || 'No description provided.' %></p>
            
            <div class="d-flex gap-2 mt-4">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
                    <i class="fas fa-edit me-2"></i>Edit
                </a>
                
                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this listing?')">
                        <i class="fas fa-trash me-2"></i>Delete
                    </button>
                </form>
            </div>
        </div>
        
        <div class="card-footer text-muted">
            <small>Listing ID: <%= listing._id %></small>
        </div>
    </div>
</body>