<% layout("/layouts/boilerplate") %>
<body>
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="card shadow">
                <div class="card-body py-5">
                    <i class="fas fa-exclamation-triangle text-danger display-1 mb-4"></i>
                    <h1 class="text-danger"><%= err.statusCode || 500 %></h1>
                    <h3 class="mb-4"><%= err.message %></h3>
                    <p class="text-muted">Something went wrong. Please try again later.</p>
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/" class="btn btn-primary">
                            <i class="fas fa-home me-2"></i>Go Home
                        </a>
                        <a href="/listings" class="btn btn-outline-primary">
                            <i class="fas fa-list me-2"></i>View Listings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>